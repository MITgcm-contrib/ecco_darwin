# ---- NS-RAD .gitignore ----

# Model run outputs (regenerable via tools/build_all.sh; large, ~GB)
runs/

# Build artifacts: NOTHING generated by tools/build_all.sh is tracked. The combined
# report is ~32 MB and the movies ~2 MB, and both are fully reproducible from a model
# run, so keeping them in history would bloat every clone for no benefit. Rebuild with
# `tools/build_all.sh --figures-only` (which recreates the six part-PDFs, stitches them
# into the report, then removes them), not `make_report.py` alone.
docs/ns_rad_model_summary.pdf
docs/ns_rad_model_schematic.pdf
docs/ns_rad_geometry.pdf
docs/ns_rad_river_networks.pdf
docs/ns_rad_diagnostics.pdf
docs/ns_rad_validation.pdf
docs/ns_rad_report.pdf
docs/idealized_verification.pdf
docs/NS-RAD_running_instructions.docx
docs/movies/

# Legacy per-field text outputs (NetCDF is the default; .dat are transient)
*.dat

# Python / Numba caches
__pycache__/
*.py[cod]
*.nbc
*.nbi
.ipynb_checkpoints/

# OS / editor / IDE
.DS_Store
.idea/
*.swp
*~

# Claude Code workspace (not project content)
.claude/

# Scratch
*.tmp
scratch/
