 9.84, 10.80, 11.80, 12.86, 13.97, 15.11, 16.30, 17.51, 18.76, 20.02,
 21.30, 22.59, 23.88, 25.17, 26.45, 27.48, 28.69, 29.93, 30.86, 32.62,
 35.03, 38.07, 41.39, 42.27, 44.46, 47.65, 51.61, 56.16, 61.07, 66.12,
 71.20, 76.27, 83.02, 90.32, 99.72, 114.74, 132.71, 152.02, 174.18,
 198.95, 225.25, 252.00, 300.00, 381.00,

 xgOrigin=30.0071,
