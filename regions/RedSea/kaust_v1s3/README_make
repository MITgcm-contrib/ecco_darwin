# Building physics-only RedSea/kaust_v1s3 on shaheen at KAUST

==============
# 1. Get code
  git clone git@github.com:MITgcm-contrib/ecco_darwin.git
  git clone https://github.com/MITgcm/MITgcm
  cd MITgcm
  git checkout checkpoint67u
  mkdir build run

==============
# 2. Build executable
  cd build
  rm *
  module purge
  module load applications-extra compilers-extra intel/2015 openmpi/1.10.1/intel-2015 
  ../../../tools/genmake2 -mods=../code_m2/ -of=../../../tools/build_options/linux_amd64_ifort -mpi -make=gmake
  make depend
  make -j 16
